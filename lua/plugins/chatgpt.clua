-- chatgpt_history.lua
-- GPT-5-mini chat ultime pour Neovim avec sauvegarde automatique

local M = {}
local api_key = os.getenv("OPENAI_API_KEY")
local model = "gpt-5-mini"
local endpoint = "https://api.openai.com/v1/chat/completions"

local http = require("socket.http")
local ltn12 = require("ltn12")
local json = require("dkjson")
local history_file = vim.fn.stdpath("config") .. "/chatgpt_history.md"

-- Historique du chat
M.messages = {}

-- Floating window et buffer
M.buf = nil
M.win = nil

-- Couleurs
local user_hl = "ChatGPTUser"
local assistant_hl = "ChatGPTAssistant"
vim.cmd("highlight " .. user_hl .. " guifg=#569CD6 gui=bold")
vim.cmd("highlight " .. assistant_hl .. " guifg=#6A9955 gui=bold")

-- Charger l'historique existant
local function load_history()
    if vim.fn.filereadable(history_file) == 1 then
        local lines = vim.fn.readfile(history_file)
        local role = "assistant"
        for _, line in ipairs(lines) do
            if line:match("^You>") then
                role = "user"
                table.insert(M.messages, { role = "user", content = line:sub(6) })
            elseif line:match("^GPT>") then
                role = "assistant"
                table.insert(M.messages, { role = "assistant", content = line:sub(6) })
            end
        end
    end
end

-- Sauvegarder l'historique
local function save_history()
    local lines = {}
    for _, m in ipairs(M.messages) do
        if m.role == "user" then
            table.insert(lines, "You> " .. m.content)
        elseif m.role == "assistant" then
            table.insert(lines, "GPT> " .. m.content)
        end
    end
    vim.fn.writefile(lines, history_file)
end

-- Fonction GPT
local function ask_chatgpt(prompt)
    table.insert(M.messages, { role = "user", content = prompt })
    local body = { model = model, messages = M.messages, max_tokens = 4096 }
    local body_json = json.encode(body)

    local response_body = {}
    local res, code = http.request{
        url = endpoint,
        method = "POST",
        headers = {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. api_key,
            ["Content-Length"] = tostring(#body_json)
        },
        source = ltn12.source.string(body_json),
        sink = ltn12.sink.table(response_body)
    }

    if code ~= 200 then
        vim.api.nvim_err_writeln("Erreur HTTP GPT: " .. code)
        return nil
    end

    local resp = json.decode(table.concat(response_body))
    local reply = resp.choices[1].message.content
    table.insert(M.messages, { role = "assistant", content = reply })
    save_history()
    return reply
end

-- Créer / mettre à jour floating window
local function create_window()
    if not M.buf then
        M.buf = vim.api.nvim_create_buf(false, true)
        local width = math.floor(vim.o.columns * 0.7)
        local height = math.floor(vim.o.lines * 0.6)
        local row = math.floor((vim.o.lines - height) / 2 - 1)
        local col = math.floor((vim.o.columns - width) / 2)

        local opts = {
            style = "minimal",
            relative = "editor",
            width = width,
            height = height,
            row = row,
            col = col,
            border = "rounded"
        }

        M.win = vim.api.nvim_open_win(M.buf, true, opts)
        vim.api.nvim_buf_set_option(M.buf, "modifiable", true)
        vim.api.nvim_buf_set_option(M.buf, "buftype", "prompt")
        vim.fn.prompt_setprompt(M.buf, "You> ")
        vim.fn.prompt_setcallback(M.buf, function(input)
            if input ~= "" then
                local lcount = vim.api.nvim_buf_line_count(M.buf)
                vim.api.nvim_buf_set_lines(M.buf, lcount, lcount, false, { input })
                vim.api.nvim_buf_add_highlight(M.buf, -1, user_hl, lcount, 0, -1)

                local reply = ask_chatgpt(input)
                if reply then
                    local lines = vim.split(reply, "\n")
                    local start_line = vim.api.nvim_buf_line_count(M.buf)
                    vim.api.nvim_buf_set_lines(M.buf, start_line, start_line, false, lines)
                    for i = 0, #lines-1 do
                        vim.api.nvim_buf_add_highlight(M.buf, -1, assistant_hl, start_line+i, 0, -1)
                    end
                    vim.api.nvim_win_set_cursor(M.win, { vim.api.nvim_buf_line_count(M.buf), 0 })
                end
            end
        end)

        -- Charger l'historique dans le buffer
        load_history()
        local lines = {}
        for _, m in ipairs(M.messages) do
            if m.role == "user" then
                table.insert(lines, m.content)
            elseif m.role == "assistant" then
                table.insert(lines, m.content)
            end
        end
        vim.api.nvim_buf_set_lines(M.buf, 0, -1, false, lines)
    else
        vim.api.nvim_set_current_win(M.win)
    end
end

-- Commande et raccourci
function M.chatgpt()
    create_window()
end

vim.api.nvim_create_user_command("ChatGPT", M.chatgpt, {})
vim.api.nvim_set_keymap("n", "<C-g>", ":ChatGPT<CR>", { noremap = true, silent = true })

return M

